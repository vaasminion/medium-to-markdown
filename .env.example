# Medium reading list to scrape
# Find this URL by going to your Medium profile → Lists → click any list → copy the URL
READING_LIST_URL=https://medium.com/@youruser/list/reading-list

# Freedium mirror used to bypass the paywall
# Change this if the default mirror goes down (find alternatives at freedium.cfd)
FREEDIUM_BASE=https://freedium-mirror.cfd/

# Where scraped markdown files and images are saved
OUTPUT_DIR=raw

# State file that tracks already-scraped URLs (delete to re-scrape everything)
STATE_FILE=state.json

# Seconds to wait between article requests (increase if you get rate-limited)
RATE_LIMIT_SECONDS=2

# --- Docker / docker-compose only ---
# Local folder to mount as the output volume
OUTPUT_VOLUME=./output
